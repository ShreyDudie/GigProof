# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# JWT
JWT_ACCESS_SECRET="your-access-secret-key-here"
JWT_REFRESH_SECRET="your-refresh-secret-key-here"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Encryption
ENCRYPTION_KEY="32-character-encryption-key-for-aes256"

# Blockchain
POLYGON_RPC_URL="https://rpc-mumbai.maticvigil.com"
PRIVATE_KEY="your-ethereum-private-key-for-did-operations"

# SMS/OTP (Mock for development)
SMS_API_KEY="mock-sms-api-key"
SMS_API_URL="https://mock-sms-provider.com/send"

# File Upload
UPLOAD_PATH="./uploads"
MAX_FILE_SIZE="10485760" # 10MB

# Rate Limiting
RATE_LIMIT_AUTH=5
RATE_LIMIT_KYC=3
RATE_LIMIT_GENERAL=100

# CORS
ALLOWED_ORIGINS="http://localhost:3000,exp://192.168.1.1:8081"

# Logging
LOG_LEVEL="info"

# Admin
ADMIN_PHONE="+919999999999"

# Development
NODE_ENV="development"
PORT=3001